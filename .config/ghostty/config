cursor-style = block

font-size = 14
font-family = Maple Mono

macos-titlebar-style = native
macos-icon = chalkboard
macos-option-as-alt = true

window-padding-x = 4
window-padding-y = 4
window-padding-balance = true

adjust-cell-height = 6
adjust-cell-width = 0

theme = Apple System Colors Light

unfocused-split-opacity = 0.7
unfocused-split-fill = #333333
split-divider-color = #333333

background-opacity = 0.9
background-blur = 25

shell-integration-features = no-cursor

keybind = cmd+opt+h=goto_split:left
keybind = cmd+opt+j=goto_split:down
keybind = cmd+opt+k=goto_split:up
keybind = cmd+opt+l=goto_split:right

# keybind = cmd+d=new_split:right
# keybind = cmd+shift+d=new_split:down
keybind = cmd+a=new_split:left
keybind = cmd+shift+a=new_split:up
